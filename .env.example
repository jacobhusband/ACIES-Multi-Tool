# GitHub release publishing.
GITHUB_TOKEN="your_github_pat_here"

# Google AI features: use a real Google AI Studio / Gemini API key here.
# Do not put a GitHub token or other provider credential in this value.
GOOGLE_API_KEY="your_google_api_key_here"

# Google desktop OAuth sign-in.
GOOGLE_OAUTH_CLIENT_ID="your_google_oauth_client_id_here"

# Optional: some Google OAuth clients still require a client secret.
GOOGLE_CLIENT_SECRET=""

# Firebase web app config for cross-device sync.
FIREBASE_API_KEY="your_firebase_web_api_key_here"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_APP_ID="your_firebase_app_id_here"
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
