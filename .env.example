# Google AI features: use a real Google AI Studio / Gemini API key here.
# Do not put a GitHub token or other provider credential in this value.
GOOGLE_API_KEY="your_google_api_key_here"

# Google desktop OAuth sign-in.
GOOGLE_OAUTH_CLIENT_ID="your_google_oauth_client_id_here"

# Optional: some Google OAuth clients still require a client secret.
GOOGLE_CLIENT_SECRET=""
